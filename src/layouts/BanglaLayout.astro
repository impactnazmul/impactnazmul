---
import '../styles/languagelayout.css'
import BaseLayout from './BaseLayout.astro'

const { title } = Astro.props as { title?: string }

const mailSubject = encodeURIComponent(
  'ওয়েবসাইট থেকে সরাসরি মোঃ নাজমূল হুদাকে মেইল করছি'
)
---

<BaseLayout
  lang='bn'
  title={title ? `${title} · মোঃ নাজমূল হুদা` : 'মোঃ নাজমূল হুদা'}
>
  <header>
    <nav aria-label='Primary navigation'>
      <a
        id='header-home'
        href='/bn'
        ><strong>মোঃ নাজমূল হুদা</strong></a
      >
      <div id='header-menu'>
        <a href='/bn/blog'>ব্লগ</a>
        <a href={`mailto:me@nazmul-huda.com?subject=${mailSubject}`}>ইমেইল</a>
      </div>
    </nav>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <p>
      &copy; {new Date().toLocaleDateString('bn-BD', { year: 'numeric' })}
      {' '}
      <a href='/bn'>মোঃ নাজমূল হুদা</a>
    </p>
    <nav>
      <a href='/bn/blog'>ব্লগ</a>
      <a href={`mailto:me@nazmul-huda.com?subject=${mailSubject}`}>ইমেইল</a>
    </nav>
  </footer>
</BaseLayout>
