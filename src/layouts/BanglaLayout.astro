---
import BaseLayout from './BaseLayout.astro'

const { title } = Astro.props as { title: string }

const mailSubject = 'ওয়েবসাইট থেকে সরাসরি মোঃ নাজমূল হুদাকে মেইল করছি'
---

<BaseLayout
  lang='bn'
  {title}
>
  <header>
    <nav>
      <a
        id='header-home'
        href='/bn'
        >মোঃ নাজমূল হুদা</a
      >
      <div id='header-menu'>
        <a href='/bn/blog'>ব্লগ</a>
        <a href={`mailto:me@nazmul-huda.com?subject=${mailSubject}`}>ইমেইল</a>
      </div>
    </nav>
  </header>
  <slot />
  <footer>
    &copy; {new Date().toLocaleDateString('bn-BD', { year: 'numeric' })}
    {' '}
    <a href='/bn'>মোঃ নাজমূল হুদা</a>
  </footer>
</BaseLayout>

<style>
  nav {
    margin-block: 0.2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  #header-home {
    font-size: 1.25rem;
    font-weight: 450;
  }

  #header-menu {
    display: flex;
    gap: 1rem;
  }
</style>
